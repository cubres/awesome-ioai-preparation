    "# Load only to inspect classes + filenames (no augmentations here)\n",
    "base_ds = keras.utils.image_dataset_from_directory(\n",
    "    train_dir,\n",
    "    labels=\"inferred\",\n",
    "    label_mode=\"int\",\n",
    "    image_size=IMG_SIZE,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    shuffle=True,\n",
    "    seed=SEED\n",
    ")\n",
    "\n",
    "class_names = base_ds.class_names\n",
    "num_classes = len(class_names)\n",
    "\n",
    "print(\"Classes:\", class_names)\n",
    "print(\"Num classes:\", num_classes)\n",
    "\n",
    "# Grab one batch to visualize\n",
    "x_batch, y_batch = next(iter(base_ds))\n",
    "\n",
    "def show_grid(x, y, class_names, n=9):\n",
    "    plt.figure(figsize=(12, 8))\n",
    "    x = x.numpy()  # <-- convert EagerTensor -> numpy\n",
    "    for i in range(n):\n",
    "        ax = plt.subplot(3, 3, i + 1)\n",
    "        ax.imshow(x[i].astype(\"uint8\"))\n",
    "        ax.set_title(class_names[y[i]])\n",
    "        ax.axis(\"off\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Note: image_dataset_from_directory returns uint8 images by default\n",
    "show_grid(x_batch, y_batch.numpy(), class_names)\n",
    "\n",
    "# Count labels by iterating over the dataset (small enough for Kaggle training sets typically)\n",
    "label_counts = np.zeros(num_classes, dtype=int)\n",
    "for _, y in base_ds.unbatch().batch(256):\n",
    "    vals = y.numpy()\n",
    "    for v in vals:\n",
    "        label_counts[v] += 1\n",
    "\n",
    "plt.figure(figsize=(10, 4))\n",
    "plt.bar(class_names, label_counts)\n",
    "plt.xticks(rotation=45, ha=\"right\")\n",
    "plt.title(\"Class distribution in training data\")\n",
    "plt.show()\n",
    "\n",
    "data_augmentation = keras.Sequential([\n",
    "    layers.RandomFlip(\"horizontal\"),\n",
    "    layers.RandomRotation(0.10),\n",
    "], name=\"data_augmentation\")\n",
    "\n",
    "# Visualize augmented versions of one batch\n",
    "x_demo, y_demo = next(iter(base_ds))\n",
    "x_demo = x_demo[:9]\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "for i in range(9):\n",
    "    ax = plt.subplot(2, 9, i + 1)\n",
    "    ax.imshow(x_demo[i].numpy().astype(\"uint8\"))\n",
    "    ax.axis(\"off\")\n",
    "    ax.set_title(class_names[y_demo[i]])\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Apply augmentation (and preprocess later for EfficientNet)\n",
    "x_aug = data_augmentation(x_demo, training=True)\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "for i in range(9):\n",
    "    ax = plt.subplot(2, 9, i + 1)\n",
    "    ax.imshow(x_aug[i].numpy().astype(\"uint8\"))\n",
    "    ax.axis(\"off\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },

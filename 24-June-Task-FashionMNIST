    "import optuna\n",
    "import torchvision.transforms as T\n",
    "from sklearn.model_selection import StratifiedKFold\n",
    "from tqdm.auto import tqdm\n",
    "import time\n",
    "\n",
    "optuna.logging.set_verbosity(optuna.logging.WARNING)\n",
    "\n",
    "DEVICE  = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "EPOCHS  = 15\n",
    "print(f\"{'='*60}\")\n",
    "print(f\"  Device : {DEVICE}\")\n",
    "print(f\"  Epochs : {EPOCHS} (final model)\")\n",
    "print(f\"{'='*60}\")\n",
    "\n",
    "# ── Augmentation ──────────────────────────────────────────────────────────────\n",
    "train_aug = T.Compose([\n",
    "    T.RandomHorizontalFlip(),\n",
    "    T.RandomCrop(28, padding=3),\n",
    "    T.RandomRotation(10),\n",
    "    T.RandomErasing(p=0.2, scale=(0.02, 0.15)),\n",
    "])\n",
    "\n",
    "def to_tensor_4d(X):\n",
    "    return torch.tensor(X / 255.0, dtype=torch.float32).reshape(-1, 1, 28, 28)\n",
    "\n",
    "print(\"\\n[1/4] Preparing tensors...\", end=\" \", flush=True)\n",
    "X_train_t = to_tensor_4d(X_train)\n",
    "X_test_t  = to_tensor_4d(X_test).to(DEVICE)\n",
    "y_train_t = torch.tensor(y_train, dtype=torch.long)\n",
    "print(f\"done.  train={tuple(X_train_t.shape)}  test={tuple(X_test_t.shape)}\")\n",
    "\n",
    "class AugDataset(torch.utils.data.Dataset):\n",
    "    def __init__(self, X, y, augment=False):\n",
    "        self.X, self.y, self.augment = X, y, augment\n",
    "    def __len__(self): return len(self.X)\n",
    "    def __getitem__(self, i):\n",
    "        x = self.X[i]\n",
    "        if self.augment:\n",
    "            x = train_aug(x)\n",
    "        return x, self.y[i]\n",
    "\n",
    "# ── ConvNet ───────────────────────────────────────────────────────────────────\n",
    "class ConvNet(nn.Module):\n",
    "    def __init__(self, dropout):\n",
    "        super().__init__()\n",
    "        self.b1 = nn.Sequential(\n",
    "            nn.Conv2d(1,  32, 3, padding=1), nn.BatchNorm2d(32),  nn.ReLU(),\n",
    "            nn.Conv2d(32, 32, 3, padding=1), nn.BatchNorm2d(32),  nn.ReLU(),\n",
    "            nn.MaxPool2d(2),\n",
    "        )\n",
    "        self.b2 = nn.Sequential(\n",
    "            nn.Conv2d(32,  64, 3, padding=1), nn.BatchNorm2d(64),  nn.ReLU(),\n",
    "            nn.Conv2d(64,  64, 3, padding=1), nn.BatchNorm2d(64),  nn.ReLU(),\n",
    "            nn.MaxPool2d(2),\n",
    "        )\n",
    "        self.b3 = nn.Sequential(\n",
    "            nn.Conv2d(64, 128, 3, padding=1), nn.BatchNorm2d(128), nn.ReLU(),\n",
    "            nn.Conv2d(128,128, 3, padding=1), nn.BatchNorm2d(128), nn.ReLU(),\n",
    "            nn.MaxPool2d(2),\n",
    "        )\n",
    "        self.b4 = nn.Sequential(\n",
    "            nn.Conv2d(128, 256, 3, padding=1), nn.BatchNorm2d(256), nn.ReLU(),\n",
    "        )\n",
    "        self.gap = nn.AdaptiveAvgPool2d(1)\n",
    "        self.fc  = nn.Sequential(\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(256, 256), nn.ReLU(), nn.Dropout(dropout),\n",
    "            nn.Linear(256, 128), nn.ReLU(), nn.Dropout(dropout / 2),\n",
    "            nn.Linear(128, 10),\n",
    "        )\n",
    "    def forward(self, x):\n",
    "        return self.fc(self.gap(self.b4(self.b3(self.b2(self.b1(x))))))\n",
    "\n",
    "def train_and_eval(dropout, lr, wd, X_tr, y_tr, X_va, y_va, epochs, bs=128,\n",
    "                   desc=\"training\", show_bar=True):\n",
    "    model     = ConvNet(dropout).to(DEVICE)\n",
    "    optimizer = optim.AdamW(model.parameters(), lr=lr, weight_decay=wd)\n",
    "    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=epochs)\n",
    "    criterion = nn.CrossEntropyLoss(label_smoothing=0.1)\n",
    "\n",
    "    tr_dl = DataLoader(AugDataset(X_tr, y_tr, augment=True),\n",
    "                       batch_size=bs, shuffle=True,  num_workers=0, pin_memory=False)\n",
    "    va_dl = DataLoader(AugDataset(X_va, y_va, augment=False),\n",
    "                       batch_size=512, shuffle=False, num_workers=0, pin_memory=False)\n",
    "\n",
    "    epoch_bar = tqdm(range(epochs), desc=desc, leave=False,\n",
    "                     disable=not show_bar, unit=\"ep\")\n",
    "    for ep in epoch_bar:\n",
    "        model.train()\n",
    "        running_loss, running_correct, running_total = 0.0, 0, 0\n",
    "        batch_bar = tqdm(tr_dl, desc=f\"  ep{ep+1:02d} batches\",\n",
    "                         leave=False, disable=not show_bar, unit=\"b\")\n",
    "        for xb, yb in batch_bar:\n",
    "            xb, yb = xb.to(DEVICE), yb.to(DEVICE)\n",
    "            optimizer.zero_grad()\n",
    "            logits = model(xb)\n",
    "            loss   = criterion(logits, yb)\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "            running_loss    += loss.item() * len(yb)\n",
    "            running_correct += (logits.argmax(1) == yb).sum().item()\n",
    "            running_total   += len(yb)\n",
    "            batch_bar.set_postfix(\n",
    "                loss=f\"{running_loss/running_total:.4f}\",\n",
    "                acc=f\"{running_correct/running_total*100:.1f}%\"\n",
    "            )\n",
    "        scheduler.step()\n",
    "        epoch_bar.set_postfix(\n",
    "            loss=f\"{running_loss/running_total:.4f}\",\n",
    "            acc=f\"{running_correct/running_total*100:.1f}%\",\n",
    "            lr=f\"{scheduler.get_last_lr()[0]:.2e}\"\n",
    "        )\n",
    "\n",
    "    model.eval()\n",
    "    correct, total = 0, 0\n",
    "    with torch.no_grad():\n",
    "        for xb, yb in va_dl:\n",
    "            xb, yb = xb.to(DEVICE), yb.to(DEVICE)\n",
    "            correct += (model(xb).argmax(1) == yb).sum().item()\n",
    "            total   += len(yb)\n",
    "    val_acc = correct / total\n",
    "    return val_acc, model\n",
    "\n",
    "# ── Optuna ────────────────────────────────────────────────────────────────────\n",
    "SUB_N   = 15_000\n",
    "sub_idx = np.random.default_rng(42).choice(len(X_train_t), SUB_N, replace=False)\n",
    "X_sub   = X_train_t[sub_idx]\n",
    "y_sub   = y_train_t[sub_idx]\n",
    "skf     = StratifiedKFold(n_splits=3, shuffle=True, random_state=42)\n",
    "\n",
    "N_TRIALS  = 5\n",
    "trial_log = []\n",
    "\n",
    "def objective(trial):\n",
    "    dropout = trial.suggest_float(\"dropout\",      0.2,  0.45)\n",
    "    lr      = trial.suggest_float(\"lr\",           5e-4, 3e-3, log=True)\n",
    "    wd      = trial.suggest_float(\"weight_decay\", 1e-5, 5e-4, log=True)\n",
    "\n",
    "    t0   = time.time()\n",
    "    accs = []\n",
    "    for fold, (tr_idx, va_idx) in enumerate(skf.split(X_sub, y_sub)):\n",
    "        acc, _ = train_and_eval(\n",
    "            dropout, lr, wd,\n",
    "            X_sub[tr_idx], y_sub[tr_idx],\n",
    "            X_sub[va_idx], y_sub[va_idx],\n",
    "            epochs=5, bs=128,\n",
    "            desc=f\"  T{trial.number+1}/{N_TRIALS} fold{fold+1}/3\",\n",
    "            show_bar=True,\n",
    "        )\n",
    "        accs.append(acc)\n",
    "        tqdm.write(f\"    fold {fold+1}/3 → val_acc={acc*100:.2f}%\")\n",
    "\n",
    "    mean_acc = float(np.mean(accs))\n",
    "    elapsed  = time.time() - t0\n",
    "    trial_log.append((trial.number + 1, dropout, lr, wd, mean_acc))\n",
    "    tqdm.write(\n",
    "        f\"  ✓ Trial {trial.number+1}/{N_TRIALS} | \"\n",
    "        f\"acc={mean_acc*100:.2f}%  dropout={dropout:.3f}  \"\n",
    "        f\"lr={lr:.2e}  wd={wd:.2e}  ({elapsed:.0f}s)\"\n",
    "    )\n",
    "    return mean_acc\n",
    "\n",
    "print(f\"\\n[2/4] Optuna search  ({N_TRIALS} trials × 3 folds × 5 epochs on {SUB_N:,} samples)\")\n",
    "print(f\"{'─'*60}\")\n",
    "t_search = time.time()\n",
    "study = optuna.create_study(direction=\"maximize\",\n",
    "                            pruner=optuna.pruners.MedianPruner())\n",
    "study.optimize(objective, n_trials=N_TRIALS, show_progress_bar=False)\n",
    "print(f\"{'─'*60}\")\n",
    "print(f\"Search done in {time.time()-t_search:.0f}s\")\n",
    "\n",
    "best = study.best_params\n",
    "print(f\"\\n  Best → dropout={best['dropout']:.3f}  lr={best['lr']:.2e}  \"\n",
    "      f\"wd={best['weight_decay']:.2e}  val_acc={study.best_value*100:.2f}%\")\n",
    "print(f\"\\n  All trials:\")\n",
    "for num, do, lr_, wd_, acc in trial_log:\n",
    "    marker = \" ◀ best\" if abs(acc - study.best_value) < 1e-9 else \"\"\n",
    "    print(f\"    Trial {num}: acc={acc*100:.2f}%  dropout={do:.3f}  \"\n",
    "          f\"lr={lr_:.2e}  wd={wd_:.2e}{marker}\")\n",
    "\n",
    "# ── Final model ───────────────────────────────────────────────────────────────\n",
    "print(f\"\\n[3/4] Final model — full 60k, {EPOCHS} epochs\")\n",
    "print(f\"{'─'*60}\")\n",
    "t_final = time.time()\n",
    "val_acc, final_model = train_and_eval(\n",
    "    best[\"dropout\"], best[\"lr\"], best[\"weight_decay\"],\n",
    "    X_train_t, y_train_t,\n",
    "    X_train_t[:200], y_train_t[:200],\n",
    "    epochs=EPOCHS, bs=128,\n",
    "    desc=\"final model\",\n",
    "    show_bar=True,\n",
    ")\n",
    "print(f\"{'─'*60}\")\n",
    "print(f\"Final model done in {time.time()-t_final:.0f}s\")\n",
    "\n",
    "# ── Predict & submit ──────────────────────────────────────────────────────────\n",
    "print(f\"\\n[4/4] Predicting & saving submission...\")\n",
    "final_model.eval()\n",
    "with torch.no_grad():\n",
    "    predictions = final_model(X_test_t).argmax(dim=1).cpu().numpy().tolist()\n",
    "\n",
    "submission          = sample[[\"imageID\"]].copy()\n",
    "submission[\"label\"] = predictions\n",
    "submission.to_csv(OUTPUT_PATH, index=False)\n",
    "\n",
    "print(f\"  Saved → {OUTPUT_PATH}\")\n",
    "print(f\"  Prediction distribution:\")\n",
    "dist = pd.Series(predictions).value_counts().sort_index()\n",
    "for cls, cnt in dist.items():\n",
    "    bar = \"█\" * (cnt // 100)\n",
    "    print(f\"    class {cls}: {cnt:5d}  {bar}\")\n",
    "print(f\"\\n{'='*60}\")\n",
    "print(f\"  Done. submission.head(10):\")\n",
    "print(f\"{'='*60}\")\n",
    "print(submission.head(10))"
   ]

    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import DataLoader, TensorDataset\n",
    "\n",
    "TRAIN_PATH  = \"/kaggle/input/competitions/ai-biz-2026-spring-task-3/fashion-mnist_train.csv\"\n",
    "TEST_PATH   = \"/kaggle/input/competitions/ai-biz-2026-spring-task-3/fashion-mnist_test.csv\"\n",
    "SAMPLE_PATH = \"/kaggle/input/competitions/ai-biz-2026-spring-task-3/fashion-mnist_test_sample_submission.csv\"\n",
    "OUTPUT_PATH = \"/kaggle/working/submission.csv\"\n",
    " \n",
    "# ── Load ─────────────────────────────────────────────────────────────────────\n",
    "train_df = pd.read_csv(TRAIN_PATH)\n",
    "test_df  = pd.read_csv(TEST_PATH)\n",
    "sample   = pd.read_csv(SAMPLE_PATH)\n",
    " \n",
    "# Train: first column is 'label', rest are pixel1..pixel784\n",
    "y_train = train_df[\"label\"].values\n",
    "X_train = train_df.drop(columns=[\"label\"]).values.astype(np.float32)\n",
    " \n",
    "# Test: NO label column, NO imageID column — just pixel1..pixel784, rows 0..9999\n",
    "# The sample submission's imageID is simply the row index (0-based), so order is already correct\n",
    "X_test = test_df.values.astype(np.float32)\n",
    " \n",
    "print(f\"Train: {X_train.shape} | Test: {X_test.shape}\")\n",
    "\n"
   ]
